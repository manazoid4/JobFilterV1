# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
APP_URL=

# EMAIL SYSTEM (Resend)
# Get this from resend.com - much simpler than SendGrid.
RESEND_API_KEY=

# WHATSAPP
# Twilio WhatsApp delivery. Keep sandbox/from/to in E.164 format, without the "whatsapp:" prefix.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=

# Companies House
# Required for company/SIC fit-out and new-business signals.
COMPANIES_HOUSE_API_KEY=

# STRIPE
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SUPABASE — get from supabase.com → project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# EPC signals
EPC_BEARER_TOKEN=
