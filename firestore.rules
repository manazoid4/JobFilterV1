rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // For testing purposes, allowing open access as requested.
    // TODO: Implement Firebase Auth and restrict these rules.
    match /tradesmen/{document=**} {
      allow read, write: if true;
    }
    match /leads/{document=**} {
      allow read, write: if true;
    }
  }
}
